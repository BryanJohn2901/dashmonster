# Copie para .env.local (dev) ou configure na Vercel > Settings > Environment Variables.
# Valores em https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=
# Use anon (eyJ...) OU publishable (sb_publishable_...) — login usa qualquer uma das duas
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL pública do app (usado pelo webhook para disparar syncs internos)
NEXT_PUBLIC_APP_URL=https://seu-dominio.vercel.app

# Token secreto para verificação do webhook Meta Instagram
# Deve ser o mesmo valor configurado no painel Meta Developer → Webhooks
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=dashmonster_ig_webhook_v1

# ─── Instagram OAuth (Meta App) ───────────────────────────────────────────────
# Crie um App em https://developers.facebook.com/apps → produtos "Facebook Login"
# + "Instagram Graph API". Submeta App Review p/ instagram_manage_insights e
# pages_read_engagement (Advanced Access) para funcionar fora dos usuários de teste.
META_APP_ID=
META_APP_SECRET=
# Deve bater EXATAMENTE com a URL cadastrada em Facebook Login → Valid OAuth Redirect URIs
META_OAUTH_REDIRECT_URI=https://seu-dominio.vercel.app/api/instagram/oauth/callback

# Chave de 32 bytes em base64 para AES-256-GCM dos access tokens guardados.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
IG_TOKEN_ENCRYPTION_KEY=

# Segredo do cron diário (sync-all). A Vercel Cron envia "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=

# ─── Eduzz OAuth2 (API pull, complemento ao webhook) ──────────────────────────
# Crie um App em https://console.eduzz.com → Developer Hub, com os escopos
# myeduzz_sales_read, myeduzz_subscriptions_read, myeduzz_products_read,
# myeduzz_financial_read, myeduzz_customers_read. Cadastre a URL de callback
# abaixo EXATAMENTE em "URLs de Retorno" no painel do app.
EDUZZ_CLIENT_ID=
EDUZZ_CLIENT_SECRET=
EDUZZ_OAUTH_REDIRECT_URI=https://seu-dominio.vercel.app/api/eduzz/oauth/callback
# Token Eduzz não expira (confirmado na doc oficial) — reusa o mesmo
# IG_TOKEN_ENCRYPTION_KEY acima pra cifrar o token Eduzz também (chave
# simétrica genérica, sem motivo pra ter 1 chave por integração).

# Opcional: o middleware aceita também esta variável (alguns templates Supabase).
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Opcional: tempo máximo (ms) para getUser() no proxy, entre 1000 e 30000.
# SUPABASE_AUTH_MIDDLEWARE_TIMEOUT_MS=5000
