# Copie para .env.local (dev) ou configure na Vercel > Settings > Environment Variables.
# Valores em https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opcional: o middleware aceita também esta variável (alguns templates Supabase).
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Opcional: tempo máximo (ms) para getUser() no proxy, entre 1000 e 30000.
# SUPABASE_AUTH_MIDDLEWARE_TIMEOUT_MS=5000

# Apps Script — Dashboard Perpétuo
# URL da Web App publicada em: Extensões > Apps Script > Implantar > Web App
# SEM prefixo NEXT_PUBLIC_ — chave permanece no servidor.
APPS_SCRIPT_URL=https://script.google.com/macros/s/SEU_SCRIPT_ID/exec
APPS_SCRIPT_API_KEY=sua_api_key_aqui
